[Unit]
Description=Socrate OAuth 2.1 / OIDC server (OAuth :8080 public, admin API :8081 loopback)
Documentation=https://github.com/ovander/go-oauth2
After=network-online.target postgresql.service
Wants=network-online.target
Requires=postgresql.service

[Service]
Type=simple
User=socrate
Group=socrate
EnvironmentFile=/etc/socrate/socrate.env
ExecStart=/usr/local/bin/socrate
Restart=on-failure
RestartSec=5

# ── Hardening (Tier-0 control plane) ─────────────────────────────────────────
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true
PrivateDevices=true
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
ProtectClock=true
ProtectHostname=true
RestrictRealtime=true
RestrictSUIDSGID=true
RestrictNamespaces=true
LockPersonality=true
MemoryDenyWriteExecute=true
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
SystemCallFilter=@system-service
SystemCallErrorNumber=EPERM
CapabilityBoundingSet=
AmbientCapabilities=
# Socrate's RSA signing keys live on disk at KEYS_PATH and are rotated at
# runtime, so that directory must be writable; everything else stays read-only
# under ProtectSystem=strict. Keep this in sync with KEYS_PATH in socrate.env.
ReadWritePaths=/var/lib/socrate/keys

[Install]
WantedBy=multi-user.target
