# /etc/socrate/socrate.env — Socrate backend (go-oauth2)
# Copy to /etc/socrate/socrate.env, fill secrets, chmod 600, owner socrate.
# See go-oauth2/.env.example for the full set of tunables.

ENV=production

# Dual-port mode: public OAuth on 8080, admin API on 8081 bound to loopback.
PORT=8080
ADMIN_PORT=8081
ADMIN_BIND_HOST=127.0.0.1

# Public issuer URL (must match the OAuth subdomain).
OAUTH_ISSUER=https://socrate.vandermoten.eu

# Postgres (local).
DATABASE_URL=postgres://socrate:CHANGE_ME@127.0.0.1:5432/socrate?sslmode=disable

# >=32-byte random secret (e.g. `openssl rand -hex 32`). REQUIRED in production.
SECRET_KEY_BASE=CHANGE_ME_32_BYTES_MIN

# RSA signing-key directory. REQUIRED to be an ABSOLUTE path in production (the
# server refuses to start otherwise). Must be writable by the socrate user for
# key rotation, and must match ReadWritePaths in socrate.service.
KEYS_PATH=/var/lib/socrate/keys

# CORS: the browser origins allowed to call the APIs. Note that with the BFF,
# monitoring calls are same-origin; admin SPA is cross-origin until it gets a BFF.
ALLOWED_ORIGINS=https://monitoring.vandermoten.eu,https://admin.vandermoten.eu

# Schema migrations are applied deliberately, not on every boot.
AUTO_MIGRATE=false

# Tier-0 step-up freshness window (seconds) for destructive admin actions.
ADMIN_ELEVATION_MAX_AGE=300
