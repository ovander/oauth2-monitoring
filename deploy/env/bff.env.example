# /etc/socrate/bff.env — Socrate monitoring BFF
# Copy to /etc/socrate/bff.env, chmod 600, owner socrate.

# Bind loopback — Caddy fronts it on monitoring.vandermoten.eu.
BFF_LISTEN_ADDR=127.0.0.1:8090

# Internal admin API (loopback). The BFF is its only client for this app.
BFF_ADMIN_UPSTREAM=http://127.0.0.1:8081

# ── Phase 2+ (server-side sessions / token custody) — not used by Phase 1 ──────
# BFF_OAUTH_UPSTREAM=http://127.0.0.1:8080
# BFF_PUBLIC_ORIGIN=https://monitoring.vandermoten.eu
# BFF_CLIENT_ID=socrate-monitor
# BFF_CLIENT_SECRET=CHANGE_ME            # confidential client — server-side only
# BFF_SESSION_DSN=postgres://socrate:CHANGE_ME@127.0.0.1:5432/socrate?sslmode=disable
# BFF_SESSION_IDLE=30m
# BFF_SESSION_ABSOLUTE=8h
