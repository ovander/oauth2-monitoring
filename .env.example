# ── oauth2-monitor environment variables ───────────────────────────────────────
# Copy this file to .env (for local dev) or set these as build-time args in CI.
# All VITE_* variables are inlined at build time by Vite — never put secrets here.
# The monitoring console is a PUBLIC OAuth 2.1 client and uses PKCE only; there
# is no client secret anywhere in this application.

# ── OAuth2 / Admin Backend URLs ────────────────────────────────────────────────
VITE_ADMIN_URL=http://localhost:8081
VITE_OAUTH_URL=http://localhost:8080

# Dev-only proxy upstreams (vite dev server). Default to the URLs above.
# DEV_API_PROXY_TARGET=http://localhost:8081
# DEV_OAUTH_PROXY_TARGET=http://localhost:8080

# ── OAuth2 Client (public / PKCE — no secret) ──────────────────────────────────
VITE_CLIENT_ID=security-monitor
VITE_REDIRECT_URI=http://localhost:5181/callback
VITE_SCOPES=openid,profile,email

# ── Role-based Access Control ──────────────────────────────────────────────────
#
# VITE_ADMIN_ROLES  — full access: block IPs, manage alert rules, acknowledge alerts.
#                     Grant only to DevOps / security engineers.
#                     Never use generic end-user roles (e.g. "user") here.
#
# VITE_VIEWER_ROLES — read-only access: dashboards, events, reports.
#                     Grant to developers or managers who need visibility but not
#                     the ability to take destructive actions.
#
# Users with neither role see the Unauthorised page.
# Users with a viewer role see the same UI but destructive action buttons are hidden.
#
VITE_ADMIN_ROLES=admin,monitor_admin
VITE_VIEWER_ROLES=monitor_viewer

# ── Nginx runtime variable (Docker / docker-compose) ──────────────────────────
# Used by the nginx.conf proxy_pass if you enable the /api/ block.
# ADMIN_URL=http://admin-backend:8081
